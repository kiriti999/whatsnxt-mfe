# Copy to .env.local for local development.
# In production, set the same keys in your host (Vercel, Docker, etc.) before `next build` when possible.

# Public API root (used for lab client and inlined into NEXT_PUBLIC_BFF_HOST_LAB_API via next.config).
NEXT_PUBLIC_API_URL=http://localhost:4444/api/v1

# Optional: server-only lab BFF base for homepage RSC and app/api/lab/list (browser can still use NEXT_PUBLIC_* only).
# If unset, server code falls back to NEXT_PUBLIC_BFF_HOST_LAB_API / NEXT_PUBLIC_API_URL (see fetcher/labServerQuery getLabServerBaseUrl).
# BFF_HOST_LAB_API=http://localhost:4444/api/v1
