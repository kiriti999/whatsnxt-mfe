{
  "name": "whatsnxt-bff",
  "description": "whatsnxt backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "author": {
    "name": "Kiriti Komaragiri"
  },
  "engines": {
    "node": "24.11.0"
  },
  "scripts": {
    "pretest": "eslint .",
    "seed-local": "NODE_ENV=local node seed.js",
    "seed-prod": "NODE_ENV=prod node seed.js",
    "seed-dev": "NODE_ENV=dev node seed.js",
    "seed:shapes": "NODE_ENV=local ts-node scripts/seed-diagram-shapes.ts",
    "docker": "NODE_ENV=docker ENV=docker PORT=4444 REDIS_PORT=6379 REDIS_COMMANDER_PORT=8081 docker compose up -f docker-compose-dev.yml --build",
    "docker-dev": "NODE_ENV=dev ENV=dev PORT=4445 REDIS_PORT=6380 REDIS_COMMANDER_PORT=8082 docker compose -f docker-compose-dev.yml build node",
    "docker-prod": "NODE_ENV=prod ENV=prod PORT=4444 REDIS_PORT=6379 REDIS_COMMANDER_PORT=8081 docker compose -f docker-compose-prod.yml build node",
    "pm2-local": "NODE_ENV=docker ENV=docker pm2-dev dist/server.js -i 3",
    "pm2-dev": "NODE_ENV=dev ENV=dev pm2-runtime dist/server.js -i 3",
    "pm2-prod": "NODE_ENV=prod ENV=prod pm2-runtime dist/server.js -i 3",
    "local": "systemctl start mongod && systemctl start redis && NODE_ENV=local nodemon --exec ts-node server.ts",
    "mac": "brew services restart redis && brew services restart mongodb-community@7.0 && cross-env NODE_ENV=local nodemon --exec ts-node server.ts",
    "devold": "NODE_ENV=dev nodemon --exec ts-node server.ts",
    "dev": "brew services restart redis && brew services restart mongodb-community@7.0 && cross-env NODE_ENV=local nodemon --exec ts-node server.ts",
    "test": "vitest",
    "prod": "NODE_ENV=prod pm2-runtime start ecosystem.config.js --env prod",
    "deploy-dev": "sh deploy.dev.sh --auto dev 4445 6380 8082",
    "deploy": "sh deploy.sh --auto prod 4444 6379 8081",
    "deploy:mac": "sh deploy-mac.sh --auto prod 4444 6379 8081",
    "destroy": "cd terraform && terraform destroy -auto-approve",
    "terraform": "cd terraform && terraform apply -auto-approve",
    "clear-redis-cache": "redis-cli --scan --pattern 'courses_*' | xargs redis-cli DEL",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org whatsnxt --project whatsnxt-courses-bff . && sentry-cli sourcemaps upload --org whatsnxt --project whatsnxt-courses-bff .",
    "start": "node dist/server.js",
    "build": "tsc"
  },
  "dependencies": {
    "@google-analytics/data": "^4.12.1",
    "@google/generative-ai": "^0.21.0",
    "@sentry/cli": "^2.46.0",
    "@sentry/node": "^8.55.0",
    "@sentry/profiling-node": "^8.55.0",
    "@types/mongodb": "^4.0.7",
    "@whatsnxt/constants": "workspace:*",
    "@whatsnxt/core-types": "workspace:*",
    "@whatsnxt/errors": "workspace:*",
    "@whatsnxt/http-client": "workspace:*",
    "algoliasearch": "4.23.2",
    "axios": "1.7.2",
    "bcryptjs": "2.4.3",
    "body-parser": "1.19.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.0",
    "cloudinary": "1.41.0",
    "compression": "^1.8.0",
    "connect-mongo": "3.2.0",
    "cookie-parser": "1.4.4",
    "cors": "2.8.5",
    "cross-env": "6.0.3",
    "csurf": "1.10.0",
    "dotenv": "8.2.0",
    "express": "5.0.0",
    "express-oas-generator": "^1.0.48",
    "express-rate-limit": "7.4.1",
    "express-session": "1.17.1",
    "fs-extra": "^11.3.0",
    "google-auth-library": "^9.15.1",
    "graphql": "16.8.1",
    "helmet": "3.21.2",
    "http-status-codes": "2.3.0",
    "imagekit": "^5.2.0",
    "ioredis": "5.3.2",
    "joi": "17.8.4",
    "jsonwebtoken": "9.0.0",
    "moment-timezone": "^0.5.48",
    "mongodb": "^7.0.0",
    "mongoose": "7.6.10",
    "morgan": "1.9.1",
    "multer": "1.4.5-lts.1",
    "nanoid": "^3.3.11",
    "node-cron": "^3.0.3",
    "nodemailer": "6.9.3",
    "nodepub3": "^1.3.1",
    "nodepub3-typescript": "^1.3.1",
    "object-hash": "3.0.0",
    "openai": "^4.104.0",
    "pako": "^2.1.0",
    "passport": "^0.6.0",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pdfkit": "^0.17.1",
    "pm2": "5.3.0",
    "pptxgenjs": "^4.0.0",
    "razorpay": "2.9.0",
    "redis-commander": "^0.8.0",
    "reflect-metadata": "0.1.13",
    "shortid": "2.2.16",
    "streamifier": "0.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-migrate-mongoose": "^3.8.9",
    "uuid": "10.0.0",
    "winston": "3.2.1"
  },
  "devDependencies": {
    "@types/cache-manager-redis-store": "2.0.1",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "1.4.3",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/express-session": "1.18.0",
    "@types/fs-extra": "^11.0.4",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.1",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "2.0.16",
    "@types/passport-jwt": "3.0.8",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "5.0.0",
    "@typescript-eslint/parser": "5.0.0",
    "cross-env": "7.0.3",
    "eslint": "8.57.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.1.3",
    "lint-staged": "15.2.2",
    "nodemon": "3.0.1",
    "pm2": "5.3.0",
    "prettier": "3.2.5",
    "supertest": "6.1.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.15"
  }
}