{
  "name": "whatsnxt-mfe",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "author": "Arjun Komaragiri",
  "type": "module",
  "pnpm": {
    "overrides": {
      "agent-base": "7.1.1",
      "http-proxy-agent": "7.0.2",
      "https-proxy-agent": "7.0.5",
      "openapi-types": "12.1.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:turbo": "cd apps/web && next dev --turbo -p 3001",
    "start": "turbo run start",
    "start:web": "cd apps/web && next start -p 3001",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check-types": "turbo run check-types",
    "find-deadcode": "ts-prune | grep -v -e 'export' -e 'used in module'",
    "knip": "knip",
    "deploy": "vercel --prod -l",
    "analyze": "cd apps/web && ANALYZE=true next build",
    "partytown": "npx partytown copylib apps/web/public/~partytown",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "22.15.31",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "eslint": "9.29.0",
    "lefthook": "^2.0.12",
    "prettier": "3.5.3",
    "turbo": "2.5.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@builder.io/partytown": "0.10.2",
    "@next/bundle-analyzer": "16.0.0",
    "@reduxjs/toolkit": "2.8.2",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tabler/icons-react": "3.34.0",
    "@tanstack/react-query": "5.51.5",
    "@tensorflow/tfjs": "^4.22.0",
    "@tiptap/core": "2.23.0",
    "@tiptap/extension-blockquote": "2.23.0",
    "@tiptap/extension-bullet-list": "2.23.0",
    "@tiptap/extension-character-count": "2.23.0",
    "@tiptap/extension-code-block-lowlight": "2.23.0",
    "@tiptap/extension-color": "2.23.0",
    "@tiptap/extension-focus": "2.23.0",
    "@tiptap/extension-font-family": "2.23.0",
    "@tiptap/extension-hard-break": "2.23.0",
    "@tiptap/extension-highlight": "2.23.0",
    "@tiptap/extension-image": "2.23.0",
    "@tiptap/extension-link": "2.23.0",
    "@tiptap/extension-list-item": "2.23.0",
    "@tiptap/extension-ordered-list": "2.23.0",
    "@tiptap/extension-table": "2.23.0",
    "@tiptap/extension-table-cell": "2.23.0",
    "@tiptap/extension-table-header": "2.23.0",
    "@tiptap/extension-table-row": "2.23.0",
    "@tiptap/extension-text-align": "2.23.0",
    "@tiptap/extension-text-style": "2.23.0",
    "@tiptap/extension-typography": "2.23.0",
    "@tiptap/extension-underline": "2.23.0",
    "@tiptap/extension-youtube": "2.23.0",
    "@tiptap/react": "2.23.0",
    "@tiptap/starter-kit": "2.23.0",
    "@vercel/analytics": "1.5.0",
    "@vercel/speed-insights": "1.2.0",
    "@whatsnxt/blogcomments": "workspace:*",
    "@whatsnxt/comments": "workspace:*",
    "@whatsnxt/core-ui": "workspace:*",
    "@whatsnxt/core-util": "workspace:*",
    "algoliasearch": "4.23.3",
    "autoprefixer": "10.4.14",
    "clsx": "2.1.1",
    "cookies-next": "6.0.0",
    "file-saver": "2.0.5",
    "highlight.js": "11.11.1",
    "html-react-parser": "5.1.10",
    "js-cookie": "3.0.5",
    "knip": "5.61.0",
    "lowlight": "3.3.0",
    "material-react-table": "3.2.1",
    "next": "16.0.7",
    "next-redux-wrapper": "8.1.0",
    "nextjs-toploader": "3.8.16",
    "nsfwjs": "^4.2.1",
    "postcss-preset-mantine": "1.15.0",
    "prosemirror-state": "1.4.3",
    "react": "19.1.0",
    "react-cookie-consent": "9.0.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.57.0",
    "react-loading-skeleton": "3.5.0",
    "react-markdown": "10.1.0",
    "react-player": "2.16.0",
    "react-razorpay": "^3.0.1",
    "react-redux": "9.2.0",
    "remark-gfm": "4.0.1",
    "sanitize-html": "2.17.0",
    "styled-components": "6.1.19",
    "swr": "2.3.3",
    "webpack": "5.99.9",
    "xior": "0.6.3"
  }
}
